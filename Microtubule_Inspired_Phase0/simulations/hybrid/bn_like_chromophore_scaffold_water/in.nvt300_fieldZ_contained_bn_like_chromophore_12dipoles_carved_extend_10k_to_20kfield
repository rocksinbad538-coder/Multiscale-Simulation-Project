# Phase 0 Day 007 — FieldZ extension for lead hybrid chromophore-bearing BN-like candidate
# Purpose:
#   Extend carved 12-dipole hybrid candidate under axial fieldZ
#   from 10k to 20k total fieldZ steps.
#
# Starting point:
#   carved hybrid fieldZ 10k state
#
# Field:
#   Ez = 0.01 V/Angstrom
#   LAMMPS real units conversion: 0.230605 kcal/(mol Angstrom e)

units           real
atom_style      full
boundary        f f f

pair_style      lj/cut/coul/cut 10.0
bond_style      harmonic
angle_style     harmonic

read_data       ../../../systems/hybrid/bn_like_chromophore_scaffold_water/outputs/bn_like_chromophore_12dipoles_carved_nvt300_fieldZ_contained_10k.data nocoeff

reset_timestep  10000

group           scaffold type 1 2
group           water type 3 4
group           oxygen type 3
group           hydrogen type 4
group           chromophore type 5 6
group           fixed_support union scaffold chromophore

mass            1 10.811
mass            2 14.007
mass            3 15.9994
mass            4 1.008
mass            5 120.0
mass            6 120.0

pair_coeff      1 1 0.0500 3.40
pair_coeff      1 2 0.0500 3.40
pair_coeff      1 3 0.0500 3.30
pair_coeff      1 4 0.0000 0.00
pair_coeff      1 5 0.0600 3.40
pair_coeff      1 6 0.0600 3.40

pair_coeff      2 2 0.0500 3.40
pair_coeff      2 3 0.0500 3.30
pair_coeff      2 4 0.0000 0.00
pair_coeff      2 5 0.0600 3.40
pair_coeff      2 6 0.0600 3.40

pair_coeff      3 3 0.1521 3.1507
pair_coeff      3 4 0.0000 0.00
pair_coeff      3 5 0.1000 3.30
pair_coeff      3 6 0.1000 3.30

pair_coeff      4 4 0.0000 0.00
pair_coeff      4 5 0.0000 0.00
pair_coeff      4 6 0.0000 0.00

pair_coeff      5 5 0.1200 3.50
pair_coeff      5 6 0.1200 3.50
pair_coeff      6 6 0.1200 3.50

bond_coeff      1 450.0 0.9572
angle_coeff     1 55.0 104.52

special_bonds   lj/coul 0.0 0.0 0.0

neighbor        2.0 bin
neigh_modify    every 1 delay 0 check yes one 4000 page 400000

timestep        0.05

velocity        fixed_support set 0.0 0.0 0.0
fix             freeze_fixed fixed_support setforce 0.0 0.0 0.0

fix             walls all wall/reflect xlo -140.0 xhi 140.0 ylo -140.0 yhi 140.0 zlo -120.0 zhi 120.0
fix             shake_water water shake 1.0e-5 100 0 b 1 a 1

fix             fieldZ water efield 0.0 0.0 0.230605

compute         twater water temp
compute         msdwater oxygen msd com yes

fix             nvt_water water nvt temp 300.0 300.0 10.0
fix_modify      nvt_water temp twater

thermo          500
thermo_style    custom step atoms temp c_twater pe ke etotal press c_msdwater[4]

dump            traj all custom 1000 ../../../systems/hybrid/bn_like_chromophore_scaffold_water/outputs/nvt300_fieldZ_contained_bn_like_chromophore_12dipoles_carved_extend_10k_to_20k.lammpstrj id mol type q x y z ix iy iz
dump_modify     traj sort id

run             10000

write_data      ../../../systems/hybrid/bn_like_chromophore_scaffold_water/outputs/bn_like_chromophore_12dipoles_carved_nvt300_fieldZ_contained_20k.data
