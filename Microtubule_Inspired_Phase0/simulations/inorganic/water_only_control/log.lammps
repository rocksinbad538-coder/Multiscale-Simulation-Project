LAMMPS (10 Dec 2025)
# Phase 0 Day 004 — Water-only axial electric-field diagnostic
# Purpose:
#   Field-induced dipole response reference without scaffold.

units           real
atom_style      full
boundary        f f f

# Styles must be defined before read_data because the data file contains coefficient sections.
pair_style      lj/cut/coul/cut 10.0
bond_style      harmonic
angle_style     harmonic

read_data       ../../../systems/inorganic/water_only_control/outputs/water_only_30000w_nvt300_contained.data
