# Phase 0 — BN-like scaffold + confined water controlled relaxation
# System: 30,000 confined water molecules
# Purpose: dynamically relax water after minimization using limited displacement.

units           real
atom_style      full
boundary        f f f

pair_style      lj/cut/coul/cut 10.0
bond_style      harmonic
angle_style     harmonic

read_data       ../../../systems/inorganic/bn_like_scaffold_water/outputs/bn_like_scaffold_water_30000w_minimized2.data

group           scaffold type 1 2
group           water type 3 4

mass            1 10.811
mass            2 14.007
mass            3 15.9994
mass            4 1.008

pair_coeff      1 1 0.0500 3.40
pair_coeff      2 2 0.0500 3.40
pair_coeff      1 2 0.0500 3.40
pair_coeff      3 3 0.1521 3.1507
pair_coeff      4 4 0.0000 0.0000
pair_coeff      1 3 0.0872 3.275
pair_coeff      2 3 0.0872 3.275
pair_coeff      1 4 0.0000 0.0000
pair_coeff      2 4 0.0000 0.0000
pair_coeff      3 4 0.0000 0.0000

bond_coeff      1 450.0 0.9572
angle_coeff     1 55.0 104.52

neighbor        2.0 bin
neigh_modify    every 1 delay 0 check yes

# Keep scaffold fixed.
fix             freeze_scaffold scaffold setforce 0.0 0.0 0.0
velocity        scaffold set 0.0 0.0 0.0

# Very conservative relaxation of water only.
# nve/limit caps maximum atomic displacement per step.
timestep        0.1

velocity        water create 10.0 12345 mom yes rot yes dist gaussian

fix             relax_int water nve/limit 0.02
fix             relax_thermo water langevin 10.0 50.0 100.0 54321 zero yes

thermo          100
thermo_style    custom step atoms temp pe ke etotal press

dump            dmp all custom 1000 ../../../systems/inorganic/bn_like_scaffold_water/outputs/relax_30000w.lammpstrj id type mol q x y z
dump_modify     dmp sort id

run             5000

unfix           relax_int
unfix           relax_thermo

write_data      ../../../systems/inorganic/bn_like_scaffold_water/outputs/bn_like_scaffold_water_30000w_relaxed.data
