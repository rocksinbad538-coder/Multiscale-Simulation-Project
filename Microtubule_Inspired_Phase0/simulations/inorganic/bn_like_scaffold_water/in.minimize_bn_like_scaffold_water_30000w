# Phase 0 — BN-like scaffold + confined water minimization
# System: 30,000 confined water molecules
# Purpose: relax initial water placement before finite-temperature equilibration.

units           real
atom_style      full
boundary        f f f

read_data       ../../../systems/inorganic/bn_like_scaffold_water/lammps/bn_like_scaffold_water_24OD_14ID_20L_30000w.data

group           scaffold type 1 2
group           water type 3 4

mass            1 10.811
mass            2 14.007
mass            3 15.9994
mass            4 1.008

pair_style      lj/cut/coul/cut 10.0

pair_coeff      1 1 0.0500 3.40
pair_coeff      2 2 0.0500 3.40
pair_coeff      1 2 0.0500 3.40
pair_coeff      3 3 0.1521 3.1507
pair_coeff      4 4 0.0000 0.0000
pair_coeff      1 3 0.0872 3.275
pair_coeff      2 3 0.0872 3.275
pair_coeff      1 4 0.0000 0.0000
pair_coeff      2 4 0.0000 0.0000
pair_coeff      3 4 0.0000 0.0000

bond_style      harmonic
angle_style     harmonic

bond_coeff      1 450.0 0.9572
angle_coeff     1 55.0 104.52

neighbor        2.0 bin
neigh_modify    every 1 delay 0 check yes

# Keep scaffold fixed during initial water relaxation.
fix             freeze_scaffold scaffold setforce 0.0 0.0 0.0

thermo          50
thermo_style    custom step atoms pe etotal press fmax

dump            dmp all custom 500 ../../../systems/inorganic/bn_like_scaffold_water/outputs/min_30000w.lammpstrj id type mol q x y z
dump_modify     dmp sort id

min_style       cg
minimize        1.0e-4 1.0e-6 1000 10000

write_data      ../../../systems/inorganic/bn_like_scaffold_water/outputs/bn_like_scaffold_water_30000w_minimized.data
