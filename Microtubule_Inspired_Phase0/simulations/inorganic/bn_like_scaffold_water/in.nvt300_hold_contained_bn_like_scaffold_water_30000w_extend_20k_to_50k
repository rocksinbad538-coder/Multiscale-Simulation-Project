# Phase 0 Day 006 — BN-like polar scaffold-water longer contained stability extension
# Purpose:
#   Extend the validated BN-like polar scaffold-water contained trajectory
#   from 20,000 total steps to 50,000 total steps.
#
# Initial state:
#   systems/inorganic/bn_like_scaffold_water/outputs/
#   bn_like_scaffold_water_30000w_nvt300_hold_extended_contained.data
#
# Notes:
#   - Scaffold remains fixed.
#   - Water is thermostatted at 300 K.
#   - Reflective finite-domain walls are retained.
#   - reset_timestep 20000 is used so the extension trajectory continues
#     the global Day 006 time index from the previous 20k state.

units           real
atom_style      full
boundary        f f f

pair_style      lj/cut/coul/cut 10.0
bond_style      harmonic
angle_style     harmonic

read_data       ../../../systems/inorganic/bn_like_scaffold_water/outputs/bn_like_scaffold_water_30000w_nvt300_hold_extended_contained.data nocoeff

reset_timestep  20000

group           scaffold type 1 2
group           water type 3 4
group           oxygen type 3
group           hydrogen type 4

mass            1 10.811
mass            2 14.007
mass            3 15.9994
mass            4 1.008

pair_coeff      1 1 0.050 3.40
pair_coeff      2 2 0.050 3.40
pair_coeff      3 3 0.1521 3.1507
pair_coeff      4 4 0.0000 0.0000
pair_coeff      1 2 0.050 3.40
pair_coeff      1 3 0.050 3.30
pair_coeff      1 4 0.0000 0.0000
pair_coeff      2 3 0.050 3.30
pair_coeff      2 4 0.0000 0.0000
pair_coeff      3 4 0.0000 0.0000

bond_coeff      1 450.0 0.9572
angle_coeff     1 55.0 104.52

special_bonds   lj/coul 0.0 0.0 0.0

neighbor        2.0 bin
neigh_modify    every 1 delay 0 check yes one 4000 page 400000

timestep        0.10

velocity        scaffold set 0.0 0.0 0.0
fix             freeze_scaffold scaffold setforce 0.0 0.0 0.0

fix             walls all wall/reflect xlo -140.0 xhi 140.0 ylo -140.0 yhi 140.0 zlo -120.0 zhi 120.0
fix             shake_water water shake 1.0e-5 100 0 b 1 a 1

compute         twater water temp
compute         msdwater oxygen msd com yes

fix             nvt_water water nvt temp 300.0 300.0 10.0
fix_modify      nvt_water temp twater

thermo          1000
thermo_style    custom step atoms temp c_twater pe ke etotal press c_msdwater[4]

dump            traj all custom 2000 ../../../systems/inorganic/bn_like_scaffold_water/outputs/nvt300_hold_contained_bn_like_extend_20k_to_50k_30000w.lammpstrj id mol type q x y z ix iy iz
dump_modify     traj sort id

run             30000

write_data      ../../../systems/inorganic/bn_like_scaffold_water/outputs/bn_like_scaffold_water_30000w_nvt300_hold_contained_50k.data
