# Phase 0 Day 005 — BN-neutralized scaffold-water axial electric-field diagnostic
# Purpose:
#   Test field-induced water dipole response in the BN-neutralized matched scaffold-water system.
#   Initial state: 20k contained BN-neutralized control.

units           real
atom_style      full
boundary        f f f

pair_style      lj/cut/coul/cut 10.0
bond_style      harmonic
angle_style     harmonic

read_data       ../../../systems/inorganic/bn_neutralized_scaffold_water/outputs/bn_neutralized_scaffold_water_30000w_nvt300_contained_20k.data nocoeff

group           scaffold type 1 2
group           water type 3 4
group           oxygen type 3
group           hydrogen type 4

mass            1 10.811
mass            2 14.007
mass            3 15.9994
mass            4 1.008

pair_coeff      1 1 0.050 3.40
pair_coeff      2 2 0.050 3.40
pair_coeff      3 3 0.1521 3.1507
pair_coeff      4 4 0.0000 0.0000
pair_coeff      1 2 0.050 3.40
pair_coeff      1 3 0.050 3.30
pair_coeff      1 4 0.0000 0.0000
pair_coeff      2 3 0.050 3.30
pair_coeff      2 4 0.0000 0.0000
pair_coeff      3 4 0.0000 0.0000

bond_coeff      1 450.0 0.9572
angle_coeff     1 55.0 104.52

special_bonds   lj/coul 0.0 0.0 0.0

neighbor        2.0 bin
neigh_modify    every 1 delay 0 check yes one 4000 page 400000

timestep        0.10

velocity        scaffold set 0.0 0.0 0.0
fix             freeze_scaffold scaffold setforce 0.0 0.0 0.0

fix             walls all wall/reflect xlo -140.0 xhi 140.0 ylo -140.0 yhi 140.0 zlo -120.0 zhi 120.0
fix             shake_water water shake 1.0e-5 100 0 b 1 a 1

compute         twater water temp
compute         msdwater oxygen msd com yes

fix             nvt_water water nvt temp 300.0 300.0 10.0
fix_modify      nvt_water temp twater

# Axial electric field.
# 0.01 V/Angstrom = 0.230605 kcal/(mol Angstrom e) in LAMMPS real units.
variable        Ez equal 0.230605
fix             axial_field water efield 0.0 0.0 ${Ez}

thermo          500
thermo_style    custom step atoms temp c_twater pe ke etotal press c_msdwater[4]

dump            traj all custom 1000 ../../../systems/inorganic/bn_neutralized_scaffold_water/outputs/nvt300_fieldZ_contained_bn_neutralized_30000w.lammpstrj id mol type q x y z ix iy iz
dump_modify     traj sort id

run             10000

write_data      ../../../systems/inorganic/bn_neutralized_scaffold_water/outputs/bn_neutralized_scaffold_water_30000w_nvt300_fieldZ_contained.data
