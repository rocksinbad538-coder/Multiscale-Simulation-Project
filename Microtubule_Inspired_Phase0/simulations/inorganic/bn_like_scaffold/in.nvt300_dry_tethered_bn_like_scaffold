# Phase 0 Day 004 — Dry/empty BN-like scaffold control
# Purpose:
#   Dry scaffold control at 300 K under the same placeholder nonbonded model.
#   Because this scaffold currently has no bonded topology, the run uses
#   harmonic positional tethers to preserve the intended tubular architecture.
#
# Interpretation:
#   This is a dry/empty geometry-control and workflow-validation simulation,
#   not a final predictive inorganic material stability simulation.

units           real
atom_style      charge
boundary        f f f

# Required before read_data because the data file contains Pair Coeffs.
pair_style      lj/cut/coul/cut 10.0

read_data       ../../../systems/inorganic/bn_like_scaffold/outputs/bn_like_scaffold_checked.data

group           scaffold type 1 2

# Explicitly restate masses and pair coeffs for clarity/reproducibility.
mass            1 10.811
mass            2 14.007

pair_coeff      1 1 0.050 3.40
pair_coeff      2 2 0.050 3.40
pair_coeff      1 2 0.050 3.40

neighbor        2.0 bin
neigh_modify    every 1 delay 0 check yes one 4000 page 400000

# Finite-box containment for dry scaffold control.
fix             walls all wall/reflect xlo -140.0 xhi 140.0 ylo -140.0 yhi 140.0 zlo -120.0 zhi 120.0

# Thermal initialization.
velocity        scaffold create 300.0 845913 dist gaussian mom yes rot yes

# Harmonic tether to preserve the initial scaffold architecture.
# Units in real: kcal/mol/A^2.
# This is a restrained control, not an unconstrained material prediction.
fix             tether scaffold spring/self 10.0

fix             nvt_scaffold scaffold nvt temp 300.0 300.0 50.0

timestep        0.10

compute         tscaffold scaffold temp
fix_modify      nvt_scaffold temp tscaffold

thermo          500
thermo_style    custom step atoms temp c_tscaffold pe ke etotal press

dump            d1 all custom 1000 ../../../systems/inorganic/bn_like_scaffold/outputs/nvt300_dry_tethered_bn_like_scaffold.lammpstrj id type q x y z vx vy vz
dump_modify     d1 sort id

run             20000

write_data      ../../../systems/inorganic/bn_like_scaffold/outputs/bn_like_scaffold_nvt300_dry_tethered.data
