integrator  = steep
emtol       = 50.0
emstep      = 0.0002
nsteps      = 20000

cutoff-scheme = Verlet
nstlist     = 20
rlist       = 1.2

coulombtype = PME
rcoulomb    = 1.2

vdwtype     = Cut-off
rvdw        = 1.2

pbc         = xyz

constraints = none

freezegrps  = HBN PYR
freezedim   = Y Y Y Y Y Y

comm-mode   = None
