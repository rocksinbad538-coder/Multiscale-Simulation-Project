integrator  = steep
emtol       = 100.0
emstep      = 0.001
nsteps      = 5000

cutoff-scheme = Verlet
nstlist     = 20
rlist       = 1.2

coulombtype = PME
rcoulomb    = 1.2

vdwtype     = Cut-off
rvdw        = 1.2

pbc         = xyz

constraints = none

freezegrps  = HBN PYR
freezedim   = Y Y Y Y Y Y
